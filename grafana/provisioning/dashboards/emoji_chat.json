    },
    {
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 12
      },
      "id": 8,
      "title": "GPS Accuracy Distribution (Meters)",
      "type": "barchart",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CASE WHEN accuracy < 10 THEN '< 10m' WHEN accuracy < 30 THEN '10m - 30m' WHEN accuracy < 50 THEN '30m - 50m' ELSE '> 50m' END as accuracy_range, COUNT(*) as count FROM logs WHERE event_type = 'location_update' AND accuracy IS NOT NULL GROUP BY accuracy_range",
          "refId": "A"
        }
      ]
