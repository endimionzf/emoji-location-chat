      "title": "Event Volume (Last 24h)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT DATE_TRUNC('hour', created_at) AS \"time\", event_type AS metric, COUNT(*) AS value FROM logs WHERE created_at >= NOW() - INTERVAL '24 hours' GROUP BY 1, 2 ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": {
