      "id": 6,
      "title": "Popular Emojis (Last 24h)",
      "type": "barchart",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT emoji as \"Emoji\", COUNT(*) as \"Count\" FROM emoji_drops WHERE created_at > now() - interval '24 hours' GROUP BY emoji ORDER BY \"Count\" DESC LIMIT 10",
          "refId": "A"
        }
